# ──────────────────────────────────────────────────────────────────────────────
# 5iveArts — Environment Variables
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to version control.
# ──────────────────────────────────────────────────────────────────────────────

# ── Stripe ────────────────────────────────────────────────────────────────────
# Find these in the Stripe Dashboard → Developers → API keys
STRIPE_SECRET_KEY=sk_test_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...

# Stripe webhook signing secret (from `stripe listen --forward-to localhost:3000/api/webhooks/stripe`)
STRIPE_WEBHOOK_SECRET=whsec_...

# ── Packlink ──────────────────────────────────────────────────────────────────
# Your Packlink PRO API key — Dashboard → API → Generate Key
PACKLINK_API_KEY=your_packlink_api_key_here

# ── Warehouse / sender address ────────────────────────────────────────────────
WAREHOUSE_POSTCODE=SW1A 1AA
WAREHOUSE_COUNTRY=GB

# ── App ───────────────────────────────────────────────────────────────────────
# Base URL used for Stripe success/cancel redirect URLs
NEXT_PUBLIC_BASE_URL=http://localhost:3000
